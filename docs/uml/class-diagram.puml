@startuml
title Class Diagram - Hệ thống Quản lý Đặt bàn Tích hợp

skinparam classAttributeIconSize 0
skinparam packageStyle rectangle
skinparam shadowing false

package "Thực thể lõi" {

    class Customer {
        - customerId: Long {PK}
        - name: String
        - phone: String
        - email: String {UNIQUE}
        - passwordHash: String {NULLABLE}
        - isVerified: Boolean = FALSE
        - verificationToken: String {NULLABLE}
        - verificationTokenExpiresAt: DateTime {NULLABLE}
        - resetToken: String {NULLABLE}
        - resetTokenExpiresAt: DateTime {NULLABLE}
    }

    class Table_Info {
        - tableId: Long {PK}
        - capacity: int
        - status: TableStatus
        - version: int {Optimistic Lock}
        - isActive: Boolean = TRUE
        - softLockUntil: DateTime {NULLABLE}
        - lockedByReservationId: Long {NULLABLE}
    }

    class Reservation {
        - reservationId: Long {PK}
        - customerId: Long {FK, Nullable}
        - accountId: Long {FK, Nullable}
        - type: ReservationType
        - guestCount: int
        - startTime: DateTime
        - endTime: DateTime
        - status: ReservationStatus
        - note: String {NULLABLE}
        - createdAt: DateTime
    }

    class Reservation_Table_Mapping {
        - mappingId: Long {PK}
        - reservationId: Long {FK}
        - tableId: Long {FK}
    }

    class Waitlist {
        - waitlistId: Long {PK}
        - customerId: Long {FK}
        - guestCount: int
        - joinedAt: DateTime
        - status: WaitlistStatus
        - allowShortSeating: Boolean = FALSE
    }

    class Account {
        - accountId: Long {PK}
        - username: String {UNIQUE}
        - passwordHash: String
        - role: UserRole
        - sessionToken: String {NULLABLE}
        - sessionExpiresAt: DateTime {NULLABLE}
    }

    class Override_Log {
        - logId: Long {PK}
        - reservationId: Long {FK}
        - accountId: Long {FK}
        - reason: String
        - createdAt: DateTime
    }
}

package "Enums" {
    enum TableStatus {
        AVAILABLE
        OCCUPIED
        OVERSTAY
    }

    enum ReservationStatus {
        CREATED
        PENDING_PAYMENT
        RESERVED
        SEATED
        COMPLETED
        CANCELLED
        NO_SHOW
        EXPIRED
    }

    enum ReservationType {
        ONLINE
        WALK_IN
    }

    enum WaitlistStatus {
        WAITING
        SEATED
        SKIPPED
    }

    enum UserRole {
        RECEPTIONIST
        MANAGER
    }
}

Customer "0..1" -- "0..*" Reservation : đặt >
Customer "1" -- "0..*" Waitlist : liên hệ >

Reservation "1" -- "0..*" Reservation_Table_Mapping : có >
Table_Info "1" -- "0..*" Reservation_Table_Mapping : được gán bởi >
Reservation "0..1" <-- "0..*" Table_Info : soft lock >

Account "0..1" -- "0..*" Reservation : xử lý >
Account "1" -- "0..*" Override_Log : ghi >
Reservation "1" -- "0..1" Override_Log : phát sinh >

Table_Info ..> TableStatus : <<use>>
Reservation ..> ReservationStatus : <<use>>
Reservation ..> ReservationType : <<use>>
Waitlist ..> WaitlistStatus : <<use>>
Account ..> UserRole : <<use>>

note bottom of Reservation
  Buffer time, giải phóng soft lock,
  giải phóng bàn sau check-out và
  xử lý NO_SHOW/EXPIRED/CANCELLED
  được thực hiện ở tầng service/scheduler.
end note

note right of Reservation_Table_Mapping
  Walk-in draft ở trạng thái CREATED
  có thể chưa có mapping cho đến khi
  lễ tân xác nhận xếp bàn.
end note

note right of Waitlist
  Name và phone là bắt buộc khi đưa khách vào waitlist.
  allowShortSeating cho phép ưu tiên xếp khách vào
  các slot PARTIAL_AVAILABLE nếu khách đã đồng ý trước.
end note

note right of Customer
  passwordHash có thể NULL với khách vãng lai
  chỉ dùng cho waitlist hoặc lưu thông tin liên hệ.
end note

@enduml
