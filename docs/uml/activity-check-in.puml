@startuml
title Sơ đồ hoạt động - Check-in
skinparam conditionStyle inside

start
:Lễ tân chọn reservation cần check-in;

if (Reservation đang ở RESERVED?) then (Có)
  if (Đã quá grace period?) then (Có)
    :Chuyển reservation sang NO_SHOW;
    :Giải phóng các bàn đã mapping;
  else (Không)
    :Kiểm tra bàn gốc;
    if (Bàn gốc sẵn sàng?) then (Có)
      :Giữ nguyên mapping;
    else (Không)
      :Tìm bàn thay thế;
      if (Có bàn thay thế?) then (Có)
        :Cập nhật reservation-table mapping;
      else (Không)
        if (Khách đến sớm?) then (Có)
          :Thông báo chờ thêm hoặc dùng waitlist;
        else (Không)
          :Trả lỗi OVERSTAY_CONFLICT;
        endif
        stop
      endif
    endif

    :Chuyển reservation sang SEATED;
    :Cập nhật end_time dự kiến;
    :Cập nhật bàn = OCCUPIED;
  endif
else (Không)
  :Từ chối vì reservation không ở RESERVED;
endif

stop
@enduml
