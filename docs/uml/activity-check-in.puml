@startuml
title Activity Diagram - Quy trình Check-in

start
:Lễ tân tra cứu reservation;
:Tải Reservation và Reservation_Table_Mapping;

if (Reservation.status = RESERVED?) then (Có)
  if (NOW > start_time + 15 phút?) then (Có)
    :Từ chối check-in vì đã quá grace period;
    :Scheduler/Service đánh dấu NO_SHOW và giải phóng bàn;
    stop
  endif

  note right
    Khách đến sớm vẫn có thể check-in ngay
    nếu bàn gốc trống hoặc có bàn thay thế phù hợp.
  end note

  :Kiểm tra trạng thái bàn gốc;
  if (Bàn gốc còn trống?) then (Có)
    :Cập nhật start_time = NOW;
    :Cập nhật Reservation.status = SEATED;
    :Cập nhật Table_Info.status = OCCUPIED;
  else (Không)
    :Tìm bàn thay thế không overlap;
    if (Có bàn thay thế?) then (Có)
      :Cập nhật Reservation_Table_Mapping;
      :Cập nhật start_time = NOW;
      :Cập nhật Reservation.status = SEATED;
      :Cập nhật Table_Info.status = OCCUPIED cho bàn mới;
    else (Không)
      :Trả lỗi cho lễ tân;\nđề nghị chờ, waitlist hoặc override tùy tình huống;
      stop
    endif
  endif

  :Bắt đầu theo dõi thời gian sử dụng bàn;
else (Không)
  :Từ chối check-in vì reservation không ở trạng thái RESERVED;
endif

stop
@enduml
