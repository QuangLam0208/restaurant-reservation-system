@startuml
title Sơ đồ hoạt động - Đăng nhập khách hàng
skinparam conditionStyle inside

start
:Nhập email và mật khẩu;
:Gửi yêu cầu đăng nhập;

:Tìm tài khoản theo email;
if (Tài khoản tồn tại?) then (Có)
  if (Tài khoản đã xác minh?) then (Có)
    :So khớp mật khẩu;
    if (Mật khẩu đúng?) then (Có)
      :Tạo HTTP session;
      :Cho phép truy cập hệ thống;
    else (Không)
      :Thông báo sai email hoặc mật khẩu;
    endif
  else (Không)
    if (Mã xác minh đã hết hạn?) then (Có)
      :Gửi lại email xác minh;
    endif
    :Thông báo tài khoản chưa xác minh;
  endif
else (Không)
  :Thông báo sai email hoặc mật khẩu;
endif

stop
