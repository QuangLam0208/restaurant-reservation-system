@startuml
title Activity Diagram - Đăng nhập và cấp token
skinparam conditionStyle inside

start
:Chọn loại tài khoản;

if (Loại tài khoản?) then (Khách hàng online)
  :Nhập Email và Mật khẩu\nhoặc chọn "Quên mật khẩu";

  if (Chọn quên mật khẩu?) then (Có)
    :Nhập email đã đăng ký;
    :Tạo reset_token có hạn 15 phút;
    :Gửi email đặt lại mật khẩu;
    :Khách mở liên kết và nhập mật khẩu mới;

    if (Token hợp lệ và chưa hết hạn?) then (Có)
      :Cập nhật password_hash;
      :Vô hiệu hóa reset_token cũ;
      :Thông báo đặt lại mật khẩu thành công;
    else (Không)
      :Báo lỗi token không hợp lệ hoặc hết hạn;
    endif

  else (Đăng nhập)
    :Tra cứu Customer theo email;
    if (Tồn tại tài khoản?) then (Có)
      :So khớp password_hash;
      if (Mật khẩu đúng?) then (Có)
        if (is_verified = TRUE?) then (Có)
          :Cấp JWT / session token cho Web/App;
          :Cho phép gọi API đặt bàn online;
        else (Không)
          :Thông báo tài khoản chưa xác minh;
          :Hiển thị thao tác gửi lại email xác minh;
        endif
      else (Không)
        :Báo lỗi sai email hoặc mật khẩu;
      endif
    else (Không)
      :Báo lỗi sai email hoặc mật khẩu;
    endif
  endif

else (Nhân viên POS)
  :Nhập Username và Password;
  :Tra cứu Account theo username;

  if (Thông tin hợp lệ?) then (Có)
    :Cấp session token cho API nội bộ POS;
    :Trả token qua header X-Staff-Token;
    :Đặt thời hạn phiên = 8 giờ;
  else (Không)
    :Báo lỗi đăng nhập nhân viên;
  endif
endif

stop
@enduml
