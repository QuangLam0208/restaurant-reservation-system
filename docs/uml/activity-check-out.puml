@startuml
title Sơ đồ hoạt động - Check-out
skinparam conditionStyle inside

start
:Lễ tân chọn reservation cần check-out;

if (Reservation đang ở SEATED?) then (Có)
  :Thực hiện check-out;
  :Cập nhật end_time thực tế;
  :Chuyển reservation sang COMPLETED;

  :Scheduler chờ hết buffer time;
  if (Bàn an toàn để giải phóng?) then (Có)
    :Chuyển bàn sang AVAILABLE;
  else (Không)
    :Giữ nguyên trạng thái bàn;
  endif
else (Không)
  :Từ chối vì reservation không ở SEATED;
endif

stop
@enduml
