@startuml
title Activity Diagram - Check-out, Overstay và Hủy đặt bàn
skinparam conditionStyle inside

start
:Xác định ngữ cảnh xử lý;

if (Ngữ cảnh?) then (Check-out)
  :Lễ tân yêu cầu check-out;
  :Cập nhật Reservation.status = COMPLETED;
  :Cập nhật end_time = NOW;
  :Service/Scheduler chờ qua buffer time;
  :Giải phóng bàn và cập nhật Table_Info.status = AVAILABLE;
  :Ưu tiên xử lý khách đầu waitlist nếu có;

else (Overstay / Cancel)
  if (Reservation đang SEATED\nvà NOW > end_time?) then (Overstay)
    :Scheduler đánh dấu Table_Info.status = OVERSTAY;
    :Đẩy cảnh báo lên POS;
    :Lễ tân yêu cầu khách rời bàn;

    if (Khách chấp hành?) then (Có)
      :Thực hiện check-out bình thường;
      :Cập nhật Reservation.status = COMPLETED;
      :Cập nhật end_time = NOW;
      :Service/Scheduler giải phóng bàn sau buffer;
    else (Không)
      :Chỉ trong tình huống bất khả kháng mới cho phép Override;
      :Lễ tân nhập reason;
      :Ghi Override_Log;
      :Áp dụng phương án xử lý thủ công;
    endif

  else (Hủy trước giờ)
    :Chỉ cho phép hủy khi status = PENDING_PAYMENT hoặc RESERVED;
    if (Hủy hợp lệ?) then (Có)
      :Cập nhật Reservation.status = CANCELLED;
      :Service giải phóng soft lock hoặc bàn đã mapping;
    else (Không)
      :Từ chối hủy đơn;
    endif
  endif
endif

stop
@enduml
