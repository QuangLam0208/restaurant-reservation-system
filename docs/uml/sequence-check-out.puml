@startuml
title Sơ đồ tuần tự - Check-out và override
autonumber
skinparam actorStyle awesome
skinparam shadowing false
skinparam maxMessageSize 160

actor "Lễ tân" as Receptionist
actor "Scheduler" as Scheduler
boundary "POS" as POS
control "Hệ thống" as System
database "Cơ sở dữ liệu" as DB

Receptionist -> POS : Chọn reservation cần check-out
POS -> System : Gửi yêu cầu check-out
System -> DB : Cập nhật end_time thực tế\nCập nhật reservation = COMPLETED
System --> POS : Check-out thành công

Scheduler -> System : Quét đơn COMPLETED sau buffer time
System -> DB : Kiểm tra điều kiện an toàn
System -> DB : Cập nhật bàn = AVAILABLE

alt Có overstay gây xung đột
    Receptionist -> POS : Gửi yêu cầu override và nhập lý do
    POS -> System : Override reservation
    System -> DB : Kiểm tra đơn SEATED\nvà bàn OVERSTAY

    alt Đủ điều kiện override
        System -> DB : Forced check-out\nGiải phóng bàn\nGhi Override_Log
        System --> POS : Override thành công

    else Không đủ điều kiện
        System --> POS : Trả lỗi override
    end
end

@enduml
