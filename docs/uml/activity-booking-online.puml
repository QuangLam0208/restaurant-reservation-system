@startuml
title Activity Diagram - Đặt bàn online
skinparam conditionStyle inside

start
:Khách mở Web/App và chọn chức năng đặt bàn;

if (Đã đăng nhập và is_verified = TRUE?) then (Có)
  :Nhập guest_count, ngày, giờ, ghi chú;
  :Hệ thống tự động lấy name và phone từ tài khoản;
  :Kiểm tra dữ liệu đầu vào và thời gian đặt bàn;

  if (Yêu cầu không hợp lệ?) then (Có)
    :Trả lỗi dữ liệu không hợp lệ;
    stop
  endif

  :Tính end_time = start_time + 120 phút;
  note right
    Buffer time không lưu riêng trong Reservation.
    Buffer chỉ dùng ở service để kiểm tra khả dụng,
    short seating và giải phóng bàn.
  end note

  :Ưu tiên tìm bàn đơn đủ sức chứa;
  if (Có bàn đơn nào đủ sức chứa?) then (Có)
    :Loại bỏ các bàn đang bận hoặc soft lock;
    if (Còn bàn đơn khả dụng?) then (Có)
      :Chọn bàn nhỏ nhất đủ chỗ;
    else (Không)
      :Thông báo hiện không còn bàn đơn khả dụng;
      :Gợi ý các khung giờ còn trống gần nhất;
      stop
    endif
  else (Không)
    :Thử ghép các bàn trống;
    if (Ghép bàn được?) then (Có)
      :Chọn tổ hợp bàn tối ưu;
    else (Không)
      :Thông báo hết bàn;
      :Gợi ý các khung giờ còn trống gần nhất;
      stop
    endif
  endif

  :Tạo Reservation(type=ONLINE, status=CREATED);
  :Tạo Mapping cho các bàn đã chọn;
  :Thiết lập soft lock 5 phút;
  :Tính phí giữ bàn;
  :Cập nhật Reservation.status = PENDING_PAYMENT;
  :Điều hướng sang cổng thanh toán và bắt đầu đếm ngược 5 phút;

  if (Thanh toán thành công trong 5 phút?) then (Có)
    :Cập nhật Reservation.status = RESERVED;
    :Xóa soft lock;
    :Gửi email/SMS xác nhận;
  else (Không)
    if (Khách hủy thanh toán?) then (Có)
      :Cập nhật Reservation.status = CANCELLED;
    else (Quá hạn / thất bại)
      :Cập nhật Reservation.status = EXPIRED;
    endif
    :Service/Scheduler giải phóng soft lock;
    :Thông báo giao dịch không thành công;
  endif

else (Không)
  :Yêu cầu đăng nhập hoặc xác minh email trước khi đặt bàn;
endif

stop
@enduml
