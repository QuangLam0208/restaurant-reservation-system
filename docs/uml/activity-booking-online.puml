@startuml
title Activity Diagram - Đặt bàn online (Tích hợp Thanh toán & Soft Lock)
skinparam conditionStyle inside


start
:Khách mở Web/App;
:Nhập Tên, SĐT, Số lượng khách,\nNgày, Giờ, Ghi chú;
:Hệ thống validate dữ liệu;


if (Thiếu dữ liệu / sai định dạng?) then (Có)
:Trả lỗi;
stop
endif


if (guest_count <= 0?) then (Có)
:Trả lỗi;
stop
endif


if (Thời gian <= hiện tại\nhoặc ngoài giờ mở cửa?) then (Có)
:Trả lỗi;
stop
endif


:Tính start_time = reservation_time;
:Tính end_time = min(start_time + 120p (duration) + 10p (buffer), giờ đóng cửa);
:Lọc bàn capacity >= guest_count;
:Loại bàn bị overlap (trùng lịch);


if (Có bàn đơn phù hợp?) then (Có)
:Chọn bàn nhỏ nhất đủ chỗ;
else (Không)
:Tính phương án ghép bàn;
if (Ghép bàn được?) then (Có)
  :Chọn tổ hợp bàn tối ưu;
else (Không)
  :Thông báo hết bàn;
  :Gợi ý thời gian gần nhất còn trống;
  stop
endif
endif


' --- BẮT ĐẦU LUỒNG SOFT LOCK VÀ THANH TOÁN ---
:Tạo Reservation type=ONLINE, status=CREATED;
:Thiết lập Khóa tạm (Soft Lock) trong 5 phút;
:Tính phí giữ bàn (guest_count * 50.000 VNĐ);
:Cập nhật trạng thái status=PENDING_PAYMENT;
:Điều hướng sang Cổng thanh toán\n& Kích hoạt đếm ngược 5 phút;


if (Thanh toán thành công trước khi hết 5 phút?) then (Thành công)
:Cập nhật trạng thái status=RESERVED;
:Chốt phân bổ bàn (Tạo record trong bảng Mapping);
:Gửi Email/SMS xác nhận đặt bàn;
else (Thất bại / Hủy / Quá hạn)
:Cập nhật trạng thái status=EXPIRED / CANCELLED;
:Giải phóng Soft Lock\n(Bàn trở lại trạng thái AVAILABLE);
:Thông báo hủy giao dịch cho khách hàng;
endif


stop
@enduml
