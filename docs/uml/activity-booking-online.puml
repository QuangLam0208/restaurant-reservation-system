@startuml
title Sơ đồ hoạt động - Đặt bàn online
skinparam conditionStyle inside

start
:Khách nhập số lượng khách,\nthời gian đến và ghi chú;
:Gửi yêu cầu đặt bàn;

if (Đã đăng nhập và xác minh?) then (Có)
  :Kiểm tra điều kiện đặt bàn;
  if (Yêu cầu hợp lệ?) then (Có)
    :Tìm bàn đơn phù hợp;
    if (Không có bàn đơn?) then (Có)
      :Tìm phương án ghép bàn;
    endif

    if (Có phương án xếp bàn?) then (Có)
      :Tạo reservation = CREATED;
      :Soft lock bàn và tạo mapping;
      if (Có xung đột đồng thời?) then (Có)
        :Thông báo bàn vừa được giao dịch khác sử dụng;
        stop
      endif

      :Chuyển reservation sang PENDING_PAYMENT;
      :Khách thực hiện thanh toán;

      if (Thanh toán thành công?) then (Có)
        if (Soft lock còn hiệu lực?) then (Có)
          :Chuyển reservation sang RESERVED;
          :Giải phóng soft lock;
          :Gửi xác nhận đặt bàn;
        else (Không)
          :Thông báo giữ bàn đã hết hạn;
        endif
      else (Không)
        if (Khách hủy thanh toán?) then (Có)
          :Chuyển reservation sang CANCELLED;
          :Giải phóng soft lock;
        else (Không)
          :Tự động chuyển reservation sang EXPIRED;
          :Giải phóng soft lock;
        endif
      endif
    else (Không)
      :Thông báo hết bàn\nvà gợi ý khung giờ khác;
    endif
  else (Không)
    :Thông báo dữ liệu không hợp lệ\nhoặc vi phạm quy tắc nghiệp vụ;
  endif
else (Không)
  :Yêu cầu đăng nhập hoặc xác minh tài khoản;
endif

stop
@enduml
