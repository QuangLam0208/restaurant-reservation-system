@startuml
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam nodesep 28
skinparam ranksep 32
skinparam usecase {
  BackgroundColor White
  BorderColor #555
  ArrowColor #333
}

actor "Khách chưa đăng ký" as Guest
actor "Khách hàng online" as Customer
actor "Lễ tân" as Receptionist
actor "Quản lý" as Manager
actor "Cổng thanh toán" as PaymentGateway
actor "Scheduler" as Scheduler

Receptionist <|-- Manager

rectangle "Hệ thống Quản lý Đặt bàn Tích hợp (Online & Offline)" {

  rectangle "Xác thực và tài khoản" {
    usecase "Đăng ký tài khoản\n(UC_Register)" as UC_Register
    usecase "Xác minh email\n(UC_VerifyEmail)" as UC_VerifyEmail
    usecase "Gửi lại email xác minh\n(UC_ResendVerification)" as UC_ResendVerification
    usecase "Đăng nhập khách hàng\n(UC_CustomerLogin)" as UC_CustomerLogin
    usecase "Đăng xuất khách hàng\n(UC_CustomerLogout)" as UC_CustomerLogout
    usecase "Quên mật khẩu\n(UC_ForgotPassword)" as UC_ForgotPassword
    usecase "Đặt lại mật khẩu\n(UC_ResetPassword)" as UC_ResetPassword
    usecase "Cập nhật hồ sơ cá nhân\n(UC_UpdateProfile)" as UC_UpdateProfile
    usecase "Đổi mật khẩu\n(UC_ChangePassword)" as UC_ChangePassword
    usecase "Đăng nhập POS\n(UC_StaffLogin)" as UC_StaffLogin
    usecase "Đăng xuất POS\n(UC_StaffLogout)" as UC_StaffLogout
    usecase "Tạo tài khoản nhân viên\n(UC_CreateStaff)" as UC_CreateStaff
  }

  rectangle "Đặt bàn online" {
    usecase "Đặt bàn online\n(UC_BookOnline)" as UC_BookOnline
    usecase "Tự động phân bổ bàn\n(UC_AutoAssign)" as UC_AutoAssign
    usecase "Ghép bàn\n(UC_Merge)" as UC_Merge
    usecase "Khóa tạm bàn\n(UC_SoftLock)" as UC_SoftLock
    usecase "Thanh toán phí giữ bàn\n(UC_Payment)" as UC_Payment
    usecase "Tự động hết hạn thanh toán\n(UC_AutoExpire)" as UC_AutoExpire
    usecase "Gợi ý khung giờ thay thế\n(UC_SuggestAltTime)" as UC_SuggestAltTime
    usecase "Gửi xác nhận đặt bàn\n(UC_NotifyReservation)" as UC_NotifyReservation
    usecase "Hủy đặt bàn\n(UC_CancelReservation)" as UC_CancelReservation
  }

  rectangle "Walk-in và Waitlist" {
    usecase "Xem tùy chọn bàn walk-in\n(UC_ViewWalkInOptions)" as UC_ViewWalkInOptions
    usecase "Tạo gợi ý walk-in\n(UC_SuggestWalkIn)" as UC_SuggestWalkIn
    usecase "Xác nhận walk-in\n(UC_ConfirmWalkIn)" as UC_ConfirmWalkIn
    usecase "Hủy gợi ý walk-in\n(UC_CancelWalkInSuggestion)" as UC_CancelWalkInSuggestion
    usecase "Short seating\n(UC_ShortSeating)" as UC_ShortSeating
    usecase "Thêm vào waitlist\n(UC_AddWaitlist)" as UC_AddWaitlist
    usecase "Thông báo waitlist\n(UC_NotifyWaitlist)" as UC_NotifyWaitlist
    usecase "Xếp khách từ waitlist\n(UC_SeatWaitlist)" as UC_SeatWaitlist
    usecase "Đánh dấu missing\n(UC_MarkMissing)" as UC_MarkMissing
    usecase "Bỏ qua waitlist\n(UC_SkipWaitlist)" as UC_SkipWaitlist
  }

  rectangle "Vận hành tại chỗ" {
    usecase "Check-in\n(UC_CheckIn)" as UC_CheckIn
    usecase "Đổi bàn\n(UC_ChangeTable)" as UC_ChangeTable
    usecase "Check-out\n(UC_CheckOut)" as UC_CheckOut
    usecase "Tự động đánh dấu no-show\n(UC_AutoNoShow)" as UC_AutoNoShow
    usecase "Cảnh báo overstay\n(UC_AlertOverstay)" as UC_AlertOverstay
    usecase "Giải phóng bàn sau buffer\n(UC_ReleaseAfterBuffer)" as UC_ReleaseAfterBuffer
    usecase "Override khẩn cấp\n(UC_Override)" as UC_Override
    usecase "Ghi nhật ký override\n(UC_LogOverride)" as UC_LogOverride
  }

  rectangle "Quản trị" {
    usecase "Quản lý bàn\n(UC_ManageTables)" as UC_ManageTables
    usecase "Xem báo cáo thống kê\n(UC_ViewReports)" as UC_ViewReports
    usecase "Xem nhật ký override\n(UC_ViewOverrideLogs)" as UC_ViewOverrideLogs
    usecase "Xem cấu hình hệ thống\n(UC_ViewSystemConfig)" as UC_ViewSystemConfig
    usecase "Cập nhật cấu hình hệ thống\n(UC_UpdateSystemConfig)" as UC_UpdateSystemConfig
  }
}

Guest --> UC_Register
Guest --> UC_VerifyEmail
Guest --> UC_ResendVerification
Guest --> UC_ForgotPassword
Guest --> UC_ResetPassword

Customer --> UC_CustomerLogin
Customer --> UC_CustomerLogout
Customer --> UC_UpdateProfile
Customer --> UC_ChangePassword
Customer --> UC_BookOnline
Customer --> UC_CancelReservation

Receptionist --> UC_StaffLogin
Receptionist --> UC_StaffLogout
Receptionist --> UC_ViewWalkInOptions
Receptionist --> UC_SuggestWalkIn
Receptionist --> UC_ConfirmWalkIn
Receptionist --> UC_CancelWalkInSuggestion
Receptionist --> UC_AddWaitlist
Receptionist --> UC_NotifyWaitlist
Receptionist --> UC_SeatWaitlist
Receptionist --> UC_MarkMissing
Receptionist --> UC_SkipWaitlist
Receptionist --> UC_CheckIn
Receptionist --> UC_ChangeTable
Receptionist --> UC_CheckOut
Receptionist --> UC_Override
Receptionist --> UC_CancelReservation

Manager --> UC_CreateStaff
Manager --> UC_ManageTables
Manager --> UC_ViewReports
Manager --> UC_ViewOverrideLogs
Manager --> UC_ViewSystemConfig
Manager --> UC_UpdateSystemConfig

PaymentGateway --> UC_Payment

Scheduler --> UC_AutoExpire
Scheduler --> UC_AutoNoShow
Scheduler --> UC_AlertOverstay
Scheduler --> UC_ReleaseAfterBuffer

UC_BookOnline ..> UC_AutoAssign : <<include>>
UC_BookOnline ..> UC_SoftLock : <<include>>
UC_BookOnline ..> UC_Payment : <<include>>
UC_Merge ..> UC_AutoAssign : <<extend>>
UC_SuggestAltTime ..> UC_BookOnline : <<extend>>
UC_NotifyReservation ..> UC_Payment : <<extend>>

UC_SuggestWalkIn ..> UC_AutoAssign : <<include>>
UC_SuggestWalkIn ..> UC_SoftLock : <<include>>
UC_ShortSeating ..> UC_SuggestWalkIn : <<extend>>
UC_ShortSeating ..> UC_SeatWaitlist : <<extend>>

UC_Override ..> UC_LogOverride : <<include>>

@enduml
