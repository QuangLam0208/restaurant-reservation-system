@startuml
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam nodesep 40
skinparam ranksep 60

' ==========================================
' ĐỊNH NGHĨA CÁC ACTORS
' ==========================================
actor "Khách chưa ĐK (Guest)" as Guest
actor "Khách hàng Online" as OnlineCustomer
actor "Khách Walk-in" as WalkInCustomer
actor "Nhân viên Lễ tân" as Receptionist
actor "Quản lý (Manager)" as Manager
actor "Hệ thống (System)" as System

' Tính kế thừa
Guest <|-- OnlineCustomer

rectangle "Hệ thống Quản lý Đặt bàn Tích hợp (Online & Offline)" {

  rectangle "Phân hệ Xác thực (IAM)" {
    usecase "Đăng ký tài khoản" as UC_Register
    usecase "Đăng nhập" as UC_Login
    usecase "Quên mật khẩu" as UC_Forgot
    usecase "Xác thực thông tin" as UC_Verify
  }

  rectangle "Phân hệ Đặt bàn Online" {
    usecase "Đặt bàn trực tuyến" as UC_BookOnline
    usecase "Thanh toán phí giữ bàn" as UC_Payment
    usecase "Hủy đặt bàn" as UC_CancelReservation
  }

  rectangle "Phân hệ Xử lý Logic (Hệ thống)" {
    usecase "Tự động phân bổ bàn" as UC_AutoAssign
    usecase "Ghép bàn (Merge Tables)" as UC_Merge
    usecase "Gợi ý giờ trống" as UC_Suggest
    usecase "Tự động đánh dấu No-show" as UC_AutoNoShow
    usecase "Cảnh báo Overstay" as UC_AlertOverstay
    usecase "Khóa bàn (Optimistic/Soft Lock)" as UC_LockTable
  }

  rectangle "Phân hệ Vận hành Lễ tân (POS)" {
    usecase "Tiếp nhận khách Walk-in" as UC_HandleWalkIn
    usecase "Xếp bàn ngồi tạm (Short Seating)" as UC_ShortSeating
    usecase "Đưa vào Danh sách chờ (Waitlist)" as UC_Waitlist
    usecase "Check-in khách đặt trước" as UC_CheckIn
    usecase "Check-out hoàn tất" as UC_CheckOut
    usecase "Ghi đè thủ công (Override)" as UC_Override
    usecase "Ghi log hệ thống" as UC_Log
  }

  rectangle "Phân hệ Quản trị" {
    usecase "Quản lý sơ đồ bàn (CRUD)" as UC_ManageTables
    usecase "Xem báo cáo thống kê" as UC_ViewReports
    usecase "Quản lý log hệ thống" as UC_ManageLogs
  }
}

' ==========================================
' MỐI LIÊN KẾT TỪ ACTOR ĐẾN USE CASE
' ==========================================

' Luồng Khách hàng
Guest --> UC_Register
Guest --> UC_Forgot
OnlineCustomer --> UC_Login
OnlineCustomer --> UC_BookOnline
OnlineCustomer --> UC_CancelReservation

WalkInCustomer --> UC_HandleWalkIn
WalkInCustomer --> UC_Waitlist : "Tham gia"

' Luồng Nhân sự Nhà hàng
Receptionist --> UC_Login
Receptionist --> UC_HandleWalkIn
Receptionist --> UC_CheckIn
Receptionist --> UC_CheckOut
Receptionist --> UC_CancelReservation
Receptionist --> UC_Override

Manager --> UC_Login
Manager --> UC_ManageTables
Manager --> UC_ViewReports
Manager --> UC_ManageLogs

' Luồng Hệ thống chạy ngầm
System --> UC_AutoNoShow
System --> UC_AlertOverstay

' ==========================================
' MỐI LIÊN KẾT INCLUDE / EXTEND (NGHIỆP VỤ)
' ==========================================

' Nghiệp vụ Xác thực
UC_Login ..> UC_Verify : <<include>>
UC_BookOnline ..> UC_Login : <<include>>

' Luồng Online (CẬP NHẬT THANH TOÁN)
UC_BookOnline ..> UC_Payment : <<include>>
UC_BookOnline ..> UC_AutoAssign : <<include>>
UC_BookOnline ..> UC_LockTable : <<include>>
UC_AutoAssign <.. UC_Merge : <<extend>>
UC_BookOnline <.. UC_Suggest : <<extend>>

' Luồng Offline / Vận hành
UC_HandleWalkIn ..> UC_AutoAssign : <<include>>
UC_HandleWalkIn ..> UC_LockTable : <<include>>
UC_HandleWalkIn <.. UC_ShortSeating : <<extend>>
UC_HandleWalkIn <.. UC_Waitlist : <<extend>>

' Luồng Xử lý xung đột
UC_Override ..> UC_Log : <<include>>

@enduml