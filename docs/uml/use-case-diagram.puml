@startuml
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam shadowing false
skinparam nodesep 28
skinparam ranksep 35
skinparam usecase {
  BackgroundColor White
  BorderColor #555
  ArrowColor #333
}

actor "Khách chưa đăng ký" as Guest
actor "Khách hàng online" as Customer
actor "Lễ tân" as Receptionist
actor "Quản lý" as Manager
actor "Cổng thanh toán" as PaymentGateway
actor "Scheduler" as Scheduler

rectangle "Hệ thống Quản lý Đặt bàn Tích hợp (Online & Offline)" {

  rectangle "Xác thực" {
    usecase "UC_Register\nĐăng ký tài khoản" as UC_Register
    usecase "Xác minh email" as UC_VerifyEmail
    usecase "Gửi lại email xác minh" as UC_ResendVerification
    usecase "Đăng nhập khách hàng" as UC_CustomerLogin
    usecase "Quên mật khẩu" as UC_ForgotPassword
    usecase "Đăng nhập POS" as UC_StaffLogin
    usecase "Tạo tài khoản nhân viên" as UC_CreateStaff
  }

  rectangle "Đặt bàn online" {
    usecase "UC_BookOnline\nĐặt bàn online" as UC_BookOnline
    usecase "UC_Payment\nThanh toán phí giữ bàn" as UC_Payment
    usecase "UC_CancelReservation\nHủy đặt bàn" as UC_CancelReservation
    usecase "UC_AutoAssign\nTự động phân bổ bàn" as UC_AutoAssign
    usecase "UC_Merge\nGhép bàn" as UC_Merge
    usecase "UC_SoftLock\nKhóa tạm bàn" as UC_SoftLock
    usecase "UC_AutoExpire\nTự động hết hạn thanh toán" as UC_AutoExpire
    usecase "UC_Notify\nGửi xác nhận đặt bàn" as UC_Notify
  }

  rectangle "Walk-in & Waitlist" {
    usecase "UC_HandleWalkIn\nXử lý khách walk-in" as UC_HandleWalkIn
    usecase "UC_ShortSeating\nShort seating" as UC_ShortSeating
    usecase "UC_Waitlist\nThêm vào waitlist" as UC_Waitlist
    usecase "UC_NotifyWaitlist\nThông báo waitlist" as UC_NotifyWaitlist
    usecase "Xếp khách từ waitlist" as UC_SeatWaitlist
    usecase "Bỏ qua khách waitlist" as UC_SkipWaitlist
  }

  rectangle "Vận hành tại chỗ" {
    usecase "UC_CheckIn\nCheck-in" as UC_CheckIn
    usecase "Tìm bàn thay thế" as UC_FindAlternative
    usecase "UC_AutoNoShow\nTự động no-show" as UC_AutoNoShow
    usecase "UC_CheckOut\nCheck-out" as UC_CheckOut
    usecase "UC_AlertOverstay\nCảnh báo overstay" as UC_AlertOverstay
    usecase "UC_Override\nOverride xử lý xung đột" as UC_Override
    usecase "UC_Log\nGhi nhật ký override" as UC_Log
  }

  rectangle "Quản trị" {
    usecase "UC_ManageTables\nQuản lý bàn" as UC_ManageTables
    usecase "UC_ViewReports\nXem báo cáo" as UC_ViewReports
    usecase "UC_ManageLogs\nXem nhật ký override" as UC_ManageLogs
  }
}

Guest --> UC_Register
Guest --> UC_VerifyEmail
Guest --> UC_ForgotPassword

Customer --> UC_CustomerLogin
Customer --> UC_ResendVerification
Customer --> UC_BookOnline
Customer --> UC_Payment
Customer --> UC_CancelReservation

Receptionist --> UC_StaffLogin
Receptionist --> UC_HandleWalkIn
Receptionist --> UC_Waitlist
Receptionist --> UC_NotifyWaitlist
Receptionist --> UC_SeatWaitlist
Receptionist --> UC_SkipWaitlist
Receptionist --> UC_CheckIn
Receptionist --> UC_CheckOut
Receptionist --> UC_CancelReservation
Receptionist --> UC_Override

Manager --> UC_StaffLogin
Manager --> UC_CreateStaff
Manager --> UC_ManageTables
Manager --> UC_ViewReports
Manager --> UC_ManageLogs

PaymentGateway --> UC_Payment
Scheduler --> UC_AutoExpire
Scheduler --> UC_AutoNoShow
Scheduler --> UC_AlertOverstay

UC_BookOnline ..> UC_AutoAssign : <<include>>
UC_AutoAssign <.. UC_Merge : <<extend>>
UC_BookOnline ..> UC_SoftLock : <<include>>
UC_BookOnline ..> UC_Payment : <<include>>

UC_Payment <.. UC_AutoExpire : <<extend>>
UC_Payment <.. UC_Notify : <<extend>>

UC_HandleWalkIn ..> UC_AutoAssign : <<include>>
UC_HandleWalkIn ..> UC_SoftLock : <<include>>
UC_HandleWalkIn <.. UC_ShortSeating : <<extend>>
UC_HandleWalkIn <.. UC_Waitlist : <<extend>>

UC_Waitlist <.. UC_NotifyWaitlist : <<extend>>
UC_CheckIn <.. UC_FindAlternative : <<extend>>
UC_Override ..> UC_Log : <<include>>

@enduml
