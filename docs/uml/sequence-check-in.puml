@startuml
title Sequence Diagram - Check-in và Grace Period
autonumber

actor "Bộ lập lịch" as Scheduler
actor "Lễ tân" as Receptionist
boundary "POS UI" as POS
control "Check-in Service" as CheckInService
control "Assignment Service" as AssignmentService
database "Database" as DB

== 1. Tự động đánh dấu NO_SHOW ==
Scheduler -> CheckInService : autoMarkNoShow(now)
CheckInService -> DB : Tìm Reservation.status = RESERVED\nvà now > start_time + 15 phút

loop Với mỗi đơn quá grace period
    CheckInService -> DB : Update Reservation.status = NO_SHOW
    CheckInService -> DB : Giải phóng bàn đã mapping ở tầng service
end

== 2. Check-in thủ công tại POS ==
Receptionist -> POS : Check-in(reservation_id)
POS -> CheckInService : checkIn(reservationId, now)
CheckInService -> DB : Load Reservation + Mapping + Table_Info

alt Reservation.status != RESERVED
    CheckInService --> POS : Lỗi "Chỉ check-in đơn RESERVED"
else Reservation.status = RESERVED
    note right of CheckInService
      Khách đến sớm hoặc đúng giờ đều được ưu tiên
      dùng bàn gốc trước, nếu không được thì thử bàn thay thế.
    end note

    alt now > start_time + 15 phút
        CheckInService --> POS : Báo lỗi "Reservation đã quá grace period"
    else Bàn gốc còn trống
        CheckInService -> DB : Update Reservation.status = SEATED
        CheckInService -> DB : Update Reservation.start_time = now
        CheckInService -> DB : Update Table_Info.status = OCCUPIED
        CheckInService --> POS : Check-in thành công
    else Bàn gốc không còn trống
        CheckInService -> AssignmentService : findAlternativeTables(reservationId, now)
        AssignmentService -> DB : Tìm bàn hợp lệ không overlap,\nưu tiên bảo toàn booking online
        AssignmentService --> CheckInService : alternativeTables / none

        alt Có bàn thay thế
            CheckInService -> DB : Update Reservation_Table_Mapping
            CheckInService -> DB : Update Reservation.status = SEATED
            CheckInService -> DB : Update Reservation.start_time = now
            CheckInService -> DB : Update Table_Info.status = OCCUPIED cho bàn mới
            CheckInService --> POS : Check-in trên bàn thay thế
        else Không có bàn thay thế
            CheckInService --> POS : Báo lỗi và yêu cầu lễ tân chờ / override / xử lý waitlist
        end
    end
end

@enduml
