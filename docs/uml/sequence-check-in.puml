@startuml
title Sơ đồ tuần tự - Check-in
autonumber
skinparam actorStyle awesome
skinparam shadowing false
skinparam maxMessageSize 160

actor "Lễ tân" as Receptionist
boundary "POS" as POS
control "Hệ thống" as System
database "Cơ sở dữ liệu" as DB

Receptionist -> POS : Chọn reservation cần check-in
POS -> System : Gửi yêu cầu check-in
System -> DB : Lấy reservation, bàn đã gán\nvà cấu hình vận hành

alt Quá grace period
    System -> DB : Cập nhật reservation = NO_SHOW\nGiải phóng bàn
    System --> POS : Thông báo no-show

else Bàn gốc sẵn sàng
    System -> DB : Cập nhật reservation = SEATED\nCập nhật thời gian thực tế\nCập nhật bàn = OCCUPIED
    System --> POS : Check-in thành công

else Bàn gốc chưa sẵn sàng
    System -> DB : Tìm bàn thay thế phù hợp

    alt Có bàn thay thế
        System -> DB : Cập nhật mapping mới\nCập nhật reservation = SEATED\nCập nhật bàn = OCCUPIED
        System --> POS : Check-in vào bàn mới

    else Khách đến sớm
        System --> POS : Gợi ý chờ thêm hoặc đưa vào waitlist

    else Xung đột do overstay
        System --> POS : Trả lỗi OVERSTAY_CONFLICT
    end
end

@enduml
