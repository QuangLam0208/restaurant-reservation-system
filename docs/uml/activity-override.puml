@startuml
title Sơ đồ hoạt động - Override khẩn cấp
skinparam conditionStyle inside

start
:Hệ thống phát hiện bàn OVERSTAY;
:Lễ tân chọn reservation cần override;
:Nhập lý do override;

if (Reservation đang ở SEATED\nvà có bàn OVERSTAY?) then (Có)
  :Forced check-out;
  :Chuyển reservation sang COMPLETED;
  :Giải phóng các bàn đã mapping;
  if (Có xung đột đồng thời?) then (Có)
    :Thông báo giao dịch đang bị xử lý bởi tiến trình khác;
  else (Không)
    :Tạo Override_Log;
  endif
else (Không)
  :Từ chối override vì không đủ điều kiện;
endif

stop
@enduml
