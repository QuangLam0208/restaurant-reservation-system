@startuml
title Sơ đồ gói - Backend API

skinparam packageStyle rectangle
skinparam shadowing false
skinparam linetype ortho

package "controller" as controller
package "service" as service
package "service.impl" as service_impl
package "repository" as repository

package "model" as model {
  package "dto" as dto
  package "entity" as entity
  package "enums" as enums
}

package "mapper" as mapper
package "strategy" as strategy
package "strategy.impl" as strategy_impl
package "event" as event
package "security" as security
package "security.impl" as security_impl
package "config" as config
package "exception" as exception

controller ..> service : gọi
controller ..> dto : sử dụng

service_impl ..> service : cài đặt
service_impl ..> repository : truy cập dữ liệu
service_impl ..> entity : xử lý nghiệp vụ
service_impl ..> dto : đọc / trả dữ liệu
service_impl ..> mapper : ánh xạ
service_impl ..> strategy : phân bổ bàn
service_impl ..> event : sự kiện
service_impl ..> security : xác thực
service_impl ..> exception : ngoại lệ

repository ..> entity : quản lý
mapper ..> entity : đọc
mapper ..> dto : chuyển đổi
entity ..> enums : sử dụng

strategy_impl ..> strategy : cài đặt
strategy ..> entity : xử lý

security_impl ..> security : cài đặt
security ..> repository : xác thực
security ..> entity : đọc dữ liệu

@enduml
