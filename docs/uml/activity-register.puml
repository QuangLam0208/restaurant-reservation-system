@startuml
title Sơ đồ hoạt động - Đăng ký tài khoản
skinparam conditionStyle inside

start
:Nhập họ tên, số điện thoại,\nemail và mật khẩu;
:Gửi yêu cầu đăng ký;

if (Dữ liệu hợp lệ?) then (Có)
  :Kiểm tra email trong hệ thống;
  if (Email đã được xác minh?) then (Có)
    :Thông báo email đã tồn tại;
  else (Không)
    :Tạo mới hoặc cập nhật tài khoản\nchưa xác minh;
    :Mã hóa mật khẩu;
    :Tạo verification token;
    :Lưu tài khoản với is_verified = FALSE;
    :Gửi email xác minh;

    :Người dùng mở liên kết xác minh;
    if (Token hợp lệ?) then (Có)
      :Kích hoạt tài khoản;
      :Xóa verification token;
    else (Không)
      :Thông báo token không hợp lệ\nhoặc đã hết hạn;
    endif
  endif
else (Không)
  :Thông báo lỗi dữ liệu đầu vào;
endif

stop
@enduml
