@startuml
title Activity Diagram - Đăng ký tài khoản và xác minh email
skinparam conditionStyle inside

|Khách hàng|
start
:Mở trang đăng ký;
:Nhập name, phone, email, password;
:Bấm "Đăng ký";

|Hệ thống|
:Validate dữ liệu bắt buộc và định dạng;
if (Dữ liệu hợp lệ?) then (Không)
  :Báo lỗi dữ liệu đầu vào;
  stop
endif

:Tra cứu email trong Customer;
if (Email đã tồn tại?) then (Có)
  if (is_verified = FALSE?) then (Có)
    :Vô hiệu hóa verification_token cũ;
    :Cấp verification_token mới;
    :Gửi lại email xác minh;
    stop
  else (Không)
    :Báo lỗi "Email đã được sử dụng";
    stop
  endif
else (Không)
  :Mã hóa password_hash;
  :Tạo Customer với is_verified = FALSE;
  :Tạo verification_token và thời hạn hiệu lực;
  :Lưu dữ liệu vào hệ thống;
  :Gửi email xác minh;
endif

|Khách hàng|
:Mở email và nhấn liên kết xác minh;

|Hệ thống|
:Kiểm tra verification_token;
if (Token hợp lệ và chưa hết hạn?) then (Có)
  :Cập nhật is_verified = TRUE;
  :Vô hiệu hóa verification_token;
  :Thông báo kích hoạt tài khoản thành công;
else (Không)
  :Thông báo liên kết không hợp lệ hoặc đã hết hạn;
  :Đề nghị gửi lại email xác minh;
endif

stop
@enduml
