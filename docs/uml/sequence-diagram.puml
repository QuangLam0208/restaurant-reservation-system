@startuml
title Sequence Diagram - Hệ thống Quản lý Đặt bàn Tích hợp
autonumber
skinparam actorStyle awesome
skinparam maxMessageSize 160

actor "Khách hàng online" as Customer
actor "Lễ tân" as Receptionist
actor "Bộ lập lịch" as Scheduler
boundary "Web/App" as WebUI
boundary "POS" as POS
control "Auth Service" as Auth
control "Reservation Service" as ReservationSvc
control "Assignment Service" as Assignment
control "Waitlist Service" as WaitlistSvc
control "Notification Service" as Notify
control "Payment Gateway" as Payment
database "Database" as DB

== 1. Luồng Online: đăng nhập, đặt bàn và thanh toán ==
Customer -> WebUI : Chọn đặt bàn online
WebUI -> Auth : validateCustomerToken(token)

alt Chưa đăng nhập hoặc chưa xác minh
    Auth --> WebUI : Từ chối truy cập
    WebUI --> Customer : Yêu cầu đăng nhập / xác minh email
else Hợp lệ
    Customer -> WebUI : Nhập guest_count, start_time, note
    WebUI -> ReservationSvc : createOnlineReservation(request)
    ReservationSvc -> Assignment : findBestFit(guestCount, startTime)
    Assignment -> DB : Ưu tiên bàn đơn đủ chỗ,\nchỉ ghép bàn khi không có bàn đơn nào đủ sức chứa

    alt Có phương án phù hợp
        Assignment --> ReservationSvc : selectedTables, endTime
        ReservationSvc -> DB : Tạo Reservation(CREATED) + Mapping
        ReservationSvc -> DB : Soft lock bàn 5 phút
        ReservationSvc -> DB : Cập nhật status = PENDING_PAYMENT
        ReservationSvc --> WebUI : Trả link thanh toán

        alt Thanh toán thành công
            Customer -> Payment : Thanh toán phí giữ bàn
            Payment -> ReservationSvc : Xác nhận thành công
            ReservationSvc -> DB : Cập nhật status = RESERVED
            ReservationSvc -> DB : Xóa soft lock
            ReservationSvc -> Notify : Gửi xác nhận đặt bàn
            Notify --> Customer : Nhận thông tin đặt bàn
        else Khách hủy hoặc hết hạn
            Payment -> ReservationSvc : Failed / timeout
            ReservationSvc -> DB : Cập nhật status = CANCELLED / EXPIRED
            ReservationSvc -> DB : Giải phóng soft lock
        end
    else Không có phương án phù hợp
        ReservationSvc --> WebUI : Gợi ý khung giờ khác
        WebUI --> Customer : Chọn thời gian khác
    end
end

== 2. Luồng Walk-in và Waitlist ==
Receptionist -> POS : Nhập guest_count, name?, phone?
POS -> ReservationSvc : suggestWalkIn(guestCount, optionalInfo, now)
ReservationSvc -> Assignment : analyzeWalkInOptions(guestCount, now)
Assignment -> DB : Phân tích FULL / PARTIAL / MERGE / PARTIAL_MERGED
Assignment --> ReservationSvc : walkInOptions

alt Có phương án xếp bàn
    ReservationSvc -> DB : Tạo Reservation(status=CREATED, type=WALK_IN)
    ReservationSvc --> POS : Danh sách bàn gợi ý

    alt Phương án có short seating
        Receptionist -> POS : Xin ý kiến khách
        alt Khách đồng ý
            POS -> ReservationSvc : confirmWalkIn(reservationId, selectedTables)
            ReservationSvc -> DB : Cập nhật Mapping + SEATED + OCCUPIED
            ReservationSvc --> POS : Xếp bàn thành công
        else Khách từ chối
            ReservationSvc --> POS : Chọn phương án khác hoặc chuyển waitlist
        end
    else Phương án thông thường
        POS -> ReservationSvc : confirmWalkIn(reservationId, selectedTables)
        ReservationSvc -> DB : Cập nhật Mapping + SEATED + OCCUPIED
        ReservationSvc --> POS : Xếp bàn thành công
    end
else Hết bàn
    POS -> WaitlistSvc : addToWaitlist(name, phone, guestCount, allowShortSeating)
    WaitlistSvc -> DB : Tạo hoặc tìm Customer
    WaitlistSvc -> DB : Insert Waitlist(status=WAITING, joined_at=now)
    WaitlistSvc --> POS : Đã thêm khách vào waitlist
end

WaitlistSvc -> Assignment : analyzeWalkInOptions(waitingGuestCount, now)
Assignment --> WaitlistSvc : full/merge hoặc partial options

alt Có FULL/MERGE phù hợp cho khách đầu hàng đợi
    WaitlistSvc --> POS : Notify Waitlist
    POS -> ReservationSvc : seatWaitlist(waitlistId)
    ReservationSvc -> DB : Cập nhật Waitlist.status = SEATED
    ReservationSvc -> DB : Hoàn tất Reservation + Mapping
else allow_short_seating = TRUE và chỉ có PARTIAL/PARTIAL_MERGED
    WaitlistSvc --> POS : Notify Waitlist với short seating
    POS -> ReservationSvc : seatWaitlist(waitlistId)
    ReservationSvc -> DB : Cập nhật Waitlist.status = SEATED
    ReservationSvc -> DB : Hoàn tất Reservation + Mapping theo short seating
else Khách từ chối hoặc không liên lạc được
    POS -> WaitlistSvc : skipWaitlist(waitlistId)
    WaitlistSvc -> DB : Update Waitlist.status = SKIPPED
end

== 3. Vận hành: check-in, no-show, overstay, check-out ==
Receptionist -> POS : Check-in reservation RESERVED
POS -> ReservationSvc : checkIn(reservationId, now)
ReservationSvc -> DB : Lấy Reservation + Reservation_Table_Mapping

alt Bàn gốc còn trống hoặc có bàn thay thế
    ReservationSvc -> DB : Update Reservation.status = SEATED, start_time = now
    ReservationSvc -> DB : Update Table_Info.status = OCCUPIED
    ReservationSvc --> POS : Check-in thành công
else Không có bàn phù hợp
    ReservationSvc --> POS : Báo lỗi và yêu cầu lễ tân xử lý tiếp
end

Scheduler -> ReservationSvc : autoMarkNoShow(now)
ReservationSvc -> DB : Tìm đơn RESERVED quá start_time + 15 phút
ReservationSvc -> DB : Update Reservation.status = NO_SHOW
ReservationSvc -> DB : Giải phóng bàn / soft lock ở tầng service

Scheduler -> ReservationSvc : monitorOverstay(now)
ReservationSvc -> DB : Tìm đơn SEATED có now > end_time
ReservationSvc -> DB : Update Table_Info.status = OVERSTAY
ReservationSvc --> POS : Cảnh báo xung đột vận hành

Receptionist -> POS : Yêu cầu khách overstay rời bàn
alt Khách chấp hành
    POS -> ReservationSvc : checkOut(reservationId, now)
    ReservationSvc -> DB : Update Reservation.status = COMPLETED, end_time = now
    Scheduler -> ReservationSvc : releaseAfterBuffer(reservationId)
    ReservationSvc -> DB : Update Table_Info.status = AVAILABLE
else Tình huống bất khả kháng
    POS -> ReservationSvc : overrideConflict(reservationId, accountId, reason)
    ReservationSvc -> DB : Insert Override_Log(...)
    ReservationSvc -> DB : Áp dụng phương án xử lý thủ công
end
@enduml
