@startuml
title Sequence Diagram - Đặt bàn online
autonumber
skinparam actorStyle awesome
skinparam maxMessageSize 160

actor "Khách hàng" as Customer
boundary "Web/App UI" as UI
control "Auth Service" as Auth
control "Reservation Service" as ReservationSvc
control "Assignment Service" as Assignment
control "Payment Gateway" as PaymentGateway
control "Notification Service" as Notify
control "Release Service / Scheduler" as ReleaseSvc
database "Database" as DB

Customer -> UI : Mở chức năng đặt bàn online
UI -> Auth : validateCustomerToken(token)

alt Chưa đăng nhập hoặc chưa xác minh email
    Auth --> UI : Từ chối truy cập
    UI --> Customer : Yêu cầu đăng nhập / xác minh email
else Được phép đặt bàn
    Customer -> UI : Nhập guest_count, ngày giờ, ghi chú
    UI -> ReservationSvc : createOnlineReservation(request)
    ReservationSvc -> Assignment : findBestFit(guestCount, startTime)

    Assignment -> DB : Ưu tiên bàn đơn đủ chỗ,\nchỉ ghép bàn khi không có bàn đơn nào đủ sức chứa

    alt Có phương án xếp bàn
        Assignment --> ReservationSvc : selectedTables, endTime
        ReservationSvc -> DB : Tạo Reservation(CREATED) + Mapping
        ReservationSvc -> DB : Thiết lập soft lock 5 phút
        ReservationSvc -> DB : Cập nhật status = PENDING_PAYMENT
        ReservationSvc --> UI : paymentUrl + countdown 5 phút

        alt Thanh toán thành công
            Customer -> PaymentGateway : Thanh toán phí giữ bàn
            PaymentGateway -> ReservationSvc : Xác nhận thanh toán
            ReservationSvc -> DB : Cập nhật status = RESERVED
            ReservationSvc -> DB : Xóa soft lock
            ReservationSvc -> Notify : Gửi email/SMS xác nhận
            Notify --> Customer : Nhận thông tin đặt bàn

        else Khách hủy hoặc quá hạn thanh toán
            PaymentGateway -> ReservationSvc : Failed / timeout
            ReservationSvc -> DB : Cập nhật status = CANCELLED / EXPIRED
            ReservationSvc -> ReleaseSvc : Giải phóng soft lock
        end

    else Không có phương án phù hợp
        Assignment --> ReservationSvc : suggestedSlots
        ReservationSvc --> UI : Gợi ý khung giờ khác
        UI --> Customer : Chọn thời gian khác
    end
end

@enduml
