@startuml
title Activity Diagram tổng quát - Hệ thống quản lý đặt bàn tích hợp
skinparam conditionStyle inside

start

if (Nguồn yêu cầu?) then (Online Booking)
  :Khách nhập thông tin đặt bàn (Tên, SĐT, Số khách, Giờ);
  :Hệ thống kiểm tra dữ liệu hợp lệ;

  if (Hợp lệ?) then (Có)
    :Tính start_time, end_time (bao gồm Buffer time);
    :Tìm bàn trống / Tính toán ghép bàn;

    if (Có bàn phù hợp?) then (Có)
      :Tạo Reservation (type=ONLINE, status=CREATED);
      :Kích hoạt Khóa tạm (Soft Lock) trong 5 phút;
      :Tính phí giữ bàn (guest_count * 50.000 VNĐ);
      :Cập nhật trạng thái status=PENDING_PAYMENT;
      :Điều hướng khách sang Cổng thanh toán;

      if (Thanh toán thành công trong 5 phút?) then (Thành công)
        :Cập nhật trạng thái status=RESERVED;
        :Chốt phân bổ bàn (Mapping Table);
        :Gửi Email/SMS xác nhận cho khách;
      else (Hết thời gian / Khách hủy)
        :Cập nhật trạng thái status=EXPIRED / CANCELLED;
        :Giải phóng Soft Lock (Bàn trở lại AVAILABLE);
        stop
      endif

    else (Không)
      :Trả thông báo hết bàn;
      :Gợi ý các khung giờ gần nhất;
      stop
    endif

  else (Không)
    :Thông báo lỗi dữ liệu đầu vào;
    stop
  endif

else (Walk-in / Trực tiếp)
  :Lễ tân nhập Số lượng khách;
  :Xác định thời gian: NOW -> end_time;
  :Quét trạng thái bàn (Sức chứa & Available Window);

  if (Có bàn FULL AVAILABLE?) then (Có)
    :Gán bàn & Khóa bàn (Optimistic Locking);
    :Tạo Reservation (type=WALK_IN, status=SEATED);
  else (Không)
    if (Có bàn PARTIAL AVAILABLE?) then (Có)
      :Đề xuất Short Seating (Ngồi tạm);
      if (Khách đồng ý?) then (Đồng ý)
        :Gán bàn tạm đến thời điểm available_until;
        :Tạo Reservation (type=WALK_IN, status=SEATED);
      else (Từ chối)
        :Hệ thống quét xét ghép bàn;
      endif
    else (Không)
      :Yêu cầu Tên & SĐT để đưa vào Hàng đợi;
      :Tạo Waitlist (status=WAITING);
    endif
  endif
endif

:Hệ thống & Lễ tân theo dõi vận hành;
split
   :Check-in (Chuyển SEATED);
split again
   :Khách trễ > 15p (Chuyển NO_SHOW);
split again
   :Ngồi lố giờ (Cảnh báo OVERSTAY);
split again
   :Khách rời đi (Chuyển COMPLETED);
end split

stop
@enduml
