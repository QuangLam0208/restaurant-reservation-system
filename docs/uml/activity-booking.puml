@startuml
title Activity Diagram Tổng quát - Hệ thống Quản lý Đặt bàn Tích hợp
skinparam conditionStyle inside

start

if (Nguồn yêu cầu?) then (Online Booking)
  :Khách truy cập chức năng đặt bàn trực tuyến;
  if (Đã đăng nhập và is_verified = TRUE?) then (Có)
    :Nhập guest_count, ngày, giờ, ghi chú;
    :Tự động lấy name và phone từ tài khoản;
    :Ưu tiên tìm bàn đơn đủ sức chứa;

    if (Có bàn đơn nào đủ sức chứa?) then (Có)
      :Loại các bàn đơn đang bận hoặc soft lock;
      if (Còn bàn đơn khả dụng?) then (Có)
        :Chọn bàn đơn nhỏ nhất đủ chỗ;
      else (Không)
        :Thông báo không còn bàn đơn khả dụng;\ngợi ý khung giờ khác;
        stop
      endif
    else (Không)
      :Thử ghép các bàn trống;
      if (Ghép bàn được?) then (Có)
        :Chọn tổ hợp bàn tối ưu;
      else (Không)
        :Trả thông báo hết bàn và gợi ý khung giờ khác;
        stop
      endif
    endif

    :Tạo Reservation(status=CREATED, type=ONLINE);
    :Tạo Mapping và soft lock 5 phút;
    :Cập nhật status = PENDING_PAYMENT;
    :Điều hướng sang cổng thanh toán;

    if (Thanh toán thành công?) then (Có)
      :Cập nhật status = RESERVED;
      :Xóa soft lock;
      :Gửi xác nhận đặt bàn;
    else (Không)
      :Cập nhật status = EXPIRED hoặc CANCELLED;
      :Service/Scheduler giải phóng soft lock;
      stop
    endif
  else (Không)
    :Chuyển người dùng về trang đăng nhập hoặc xác minh email;
    stop
  endif

else (Walk-in / POS)
  :Lễ tân nhập guest_count;
  :Phân tích FULL / PARTIAL / MERGE / PARTIAL_MERGED;

  if (Có phương án xếp bàn ban đầu?) then (Có)
    :Tạo Reservation draft(status=CREATED, type=WALK_IN);
    :Lễ tân chọn bàn hoặc dùng gợi ý mặc định;

    if (Phương án là short seating?) then (Có)
      :Hiển thị available_until và hỏi ý kiến khách;
      if (Khách đồng ý?) then (Có)
        :Xác nhận xếp bàn;
        :Tạo Mapping và cập nhật status = SEATED;
        :Cập nhật Table_Info.status = OCCUPIED;
      else (Không)
        if (Có phương án khác không phải short seating?) then (Có)
          :Lễ tân chọn phương án mới;
          :Xác nhận xếp bàn;
          :Tạo Mapping và cập nhật status = SEATED;
          :Cập nhật Table_Info.status = OCCUPIED;
        else (Không)
          :Yêu cầu name + phone;
          :Tạo Waitlist(status=WAITING, allow_short_seating?);
        endif
      endif
    else (Không)
      :Xác nhận xếp bàn;
      :Tạo Mapping và cập nhật status = SEATED;
      :Cập nhật Table_Info.status = OCCUPIED;
    endif
  else (Không)
    :Yêu cầu name + phone;
    :Tạo Waitlist(status=WAITING, allow_short_seating?);
  endif
endif

:Hệ thống tiếp tục theo dõi vận hành;
split
  :Lễ tân check-in đơn RESERVED -> SEATED;
split again
  :Scheduler quét đơn RESERVED quá 15 phút -> NO_SHOW;
split again
  :Scheduler quét đơn SEATED quá end_time -> OVERSTAY;
split again
  :Lễ tân check-out -> COMPLETED,\nservice giải phóng bàn sau buffer;
end split

stop
@enduml
