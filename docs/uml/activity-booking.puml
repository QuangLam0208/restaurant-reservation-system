@startuml
title Activity Diagram tổng quát - Hệ thống quản lý đặt bàn tích hợp
skinparam conditionStyle inside

start
if (Loại yêu cầu?) then (Online)
  :Tiếp nhận yêu cầu đặt bàn online;
  :Kiểm tra điều kiện và tìm bàn;
  if (Có bàn phù hợp?) then (Có)
    :Tạo reservation và soft lock bàn;
    :Thanh toán phí giữ bàn;
    if (Thanh toán thành công?) then (Có)
      :Chuyển sang RESERVED;
    else (Không)
      :Chuyển sang CANCELLED hoặc EXPIRED;
    endif
  else (Không)
  endif
else (Walk-in)
  :Tiếp nhận khách walk-in;
  :Phân tích tùy chọn bàn;
  if (Có phương án phù hợp?) then (Có)
    :Tạo gợi ý và soft lock bàn;
    if (Lễ tân xác nhận?) then (Có)
      :Chuyển sang SEATED;
    else (Không)
      :Chuyển sang CANCELLED hoặc EXPIRED;
    endif
  else (Không)
    :Chuyển khách sang waitlist;
  endif
endif

:Hệ thống & Lễ tân theo dõi vận hành;
split
  :Check-in (Chuyển SEATED);
split again
  :Khách trễ > 15p (Chuyển NO_SHOW);
split again
  :Ngồi lố giờ (Cảnh báo OVERSTAY);
split again
  :Khách rời đi (Chuyển COMPLETED);
end split

stop
@enduml
