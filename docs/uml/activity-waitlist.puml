@startuml
title Sơ đồ hoạt động - Quản lý waitlist
skinparam conditionStyle inside

start
:Lễ tân nhập tên,\nsố điện thoại và số lượng khách;

:Kiểm tra trùng khách đang WAITING;
if (Bị trùng?) then (Có)
  :Từ chối thêm vào waitlist;
  stop
endif

:Kiểm tra còn khả năng xếp bàn ngay không;
if (Vẫn có thể xếp bàn ngay?) then (Có)
  :Từ chối đưa khách vào waitlist;
  stop
endif

:Tạo waitlist entry = WAITING;
:Đánh giá khách đầu hàng đợi có thể được xếp bàn chưa;

if (Có bàn phù hợp?) then (Có)
  :Thông báo cho khách;
  if (Liên hệ được khách?) then (Có)
    if (Khách đồng ý nhận bàn?) then (Có)
      :Chuyển sang SEATED;
    else (Không)
      :Chuyển sang SKIPPED;
    endif
  else (Không)
    :Chuyển sang MISSING\nhoặc SKIPPED;
  endif
endif

if (Khách MISSING quay lại?) then (Có)
  :Chuyển trạng thái về WAITING;
endif

stop
@enduml
