@startuml
title Sơ đồ hoạt động - Xử lý khách walk-in
skinparam conditionStyle inside

start
:Lễ tân nhập số lượng khách;

if (Số lượng khách hợp lệ?) then (Có)
  :Phân tích các tùy chọn bàn\n(FULL, MERGE, PARTIAL, PARTIAL_MERGED);
  :Lễ tân chọn bàn hoặc chọn gợi ý;
  :Kiểm tra phương án được chọn;

  if (Phương án hợp lệ?) then (Có)
    if (Đây là phương án partial?) then (Có)
      :Hỏi khách về short seating;
      if (Khách đồng ý?) then (Có)
        :Giới hạn thời gian sử dụng trước booking kế tiếp;
      else (Không)
        :Yêu cầu chọn phương án khác\nhoặc chuyển sang waitlist;
        stop
      endif
    endif

    :Tạo reservation WALK_IN = CREATED;
    :Soft lock bàn và tạo mapping;
    if (Có xung đột đồng thời?) then (Có)
      :Chuyển reservation tạm sang CANCELLED;
      :Yêu cầu lễ tân thử lại;
      stop
    endif

    if (Lễ tân xác nhận walk-in?) then (Có)
      if (Soft lock còn hiệu lực?) then (Có)
        :Chuyển reservation sang SEATED;
        :Giải phóng soft lock;
        :Cập nhật bàn = OCCUPIED;
      else (Không)
        :Chuyển reservation sang EXPIRED;
        :Yêu cầu tìm bàn lại;
      endif
    else (Không)
      :Chuyển reservation sang CANCELLED;
      :Giải phóng soft lock;
    endif
  else (Không)
    :Thông báo phương án không hợp lệ;
    :Gợi ý thử lại hoặc chuyển sang waitlist;
  endif
else (Không)
  :Thông báo lỗi dữ liệu đầu vào;
endif

stop
@enduml
