@startuml
title Sequence Diagram - Tiếp nhận khách Walk-in và Waitlist
autonumber
skinparam actorStyle awesome
skinparam maxMessageSize 160

actor "Lễ tân" as Receptionist
actor "Khách Walk-in" as WalkIn
boundary "POS UI" as UI
control "Walk-in Service" as WalkInService
control "Assignment Service" as AssignmentService
control "Waitlist Service" as WaitlistService
database "Database" as DB

Receptionist -> UI : Nhập guest_count, name?, phone?
note right of Receptionist
guest_count là bắt buộc.
name/phone có thể bỏ trống nếu xếp bàn ngay.
name/phone là bắt buộc nếu chuyển sang waitlist.
end note

UI -> WalkInService : suggestWalkIn(guestCount, optionalInfo, now)
WalkInService -> AssignmentService : analyzeWalkInOptions(guestCount, now)

group Phân tích real-time availability
    AssignmentService -> DB : Kiểm tra bàn trống và booking hiện có
    AssignmentService --> WalkInService : FULL / PARTIAL / MERGE / PARTIAL_MERGED
end

alt Có phương án xếp bàn
    WalkInService -> DB : Tạo Reservation(status=CREATED, type=WALK_IN)
    WalkInService --> UI : Danh sách bàn gợi ý + available_until

    alt PARTIAL hoặc PARTIAL_MERGED
        UI --> Receptionist : Hiển thị lựa chọn short seating
        Receptionist -> WalkIn : Hỏi khách có đồng ý ngồi tạm không?

        alt Khách đồng ý
            Receptionist -> UI : Xác nhận short seating
            UI -> WalkInService : confirmWalkIn(reservationId, selectedTables)
            WalkInService -> DB : Cập nhật Mapping + Reservation.status = SEATED
            WalkInService -> DB : Update Table_Info.status = OCCUPIED
            WalkInService --> UI : Xếp bàn thành công

        else Khách không đồng ý
            UI -> WalkInService : rejectShortSeating(reservationId)
            WalkInService -> AssignmentService : Tìm phương án khác hoặc chuyển waitlist
            AssignmentService --> WalkInService : nextOption / none

            alt Có phương án mới
                WalkInService --> UI : Cập nhật gợi ý bàn mới
                Receptionist -> UI : Chọn lại bàn
                UI -> WalkInService : confirmWalkIn(reservationId, selectedTables)
                WalkInService -> DB : Cập nhật Mapping + Reservation.status = SEATED
                WalkInService -> DB : Update Table_Info.status = OCCUPIED
                WalkInService --> UI : Xếp bàn thành công

            else Không còn phương án
                UI -> Receptionist : Yêu cầu name + phone + allow_short_seating
                Receptionist -> UI : Nhập thông tin waitlist
                UI -> WaitlistService : addToWaitlist(name, phone, guestCount, allowShortSeating)
                WaitlistService -> DB : Tạo hoặc tìm Customer
                WaitlistService -> DB : Tạo Waitlist(status=WAITING, joined_at=now)
                WaitlistService --> UI : Đã thêm vào waitlist
            end
        end

    else FULL hoặc MERGE_AVAILABLE
        Receptionist -> UI : Chọn bàn hoặc dùng gợi ý mặc định
        UI -> WalkInService : confirmWalkIn(reservationId, selectedTables)
        WalkInService -> DB : Cập nhật Mapping + Reservation.status = SEATED
        WalkInService -> DB : Update Table_Info.status = OCCUPIED
        WalkInService --> UI : Xếp bàn thành công
    end

else Hết bàn
    UI -> Receptionist : Yêu cầu name + phone + allow_short_seating
    Receptionist -> UI : Nhập thông tin waitlist
    UI -> WaitlistService : addToWaitlist(name, phone, guestCount, allowShortSeating)
    WaitlistService -> DB : Tạo hoặc tìm Customer
    WaitlistService -> DB : Tạo Waitlist(status=WAITING, joined_at=now)
    WaitlistService --> UI : Đã thêm vào waitlist
end

== Khi có bàn trống ==
WaitlistService -> DB : Lấy Waitlist đầu hàng đợi + allowShortSeating
WaitlistService -> AssignmentService : analyzeWalkInOptions(guestCount, now)
AssignmentService --> WaitlistService : full/merge hoặc partial options

alt Có FULL/MERGE phù hợp
    WaitlistService --> UI : Notify Waitlist
    alt Liên lạc được và khách nhận bàn
        UI -> WalkInService : seatWaitlist(waitlistId)
        WalkInService -> DB : Cập nhật Waitlist.status = SEATED
        WalkInService -> DB : Hoàn tất Reservation + Mapping
    else Không liên lạc được hoặc khách từ chối
        UI -> WaitlistService : skipWaitlist(waitlistId)
        WaitlistService -> DB : Update Waitlist.status = SKIPPED
    end

else allowShortSeating = TRUE và chỉ có PARTIAL/PARTIAL_MERGED
    WaitlistService --> UI : Notify Waitlist với short seating
    alt Khách đồng ý nhận bàn
        UI -> WalkInService : seatWaitlist(waitlistId)
        WalkInService -> DB : Cập nhật Waitlist.status = SEATED
        WalkInService -> DB : Hoàn tất Reservation + Mapping theo short seating
    else Không liên lạc được hoặc khách từ chối
        UI -> WaitlistService : skipWaitlist(waitlistId)
        WaitlistService -> DB : Update Waitlist.status = SKIPPED
    end
end

@enduml
